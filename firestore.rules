rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /reservations/{reservationId} {
      allow read, write: if true;
    }
    match /emails/{emailId} {
      allow read, write: if true;
    }
    match /visitorPasses/{passId} {
      allow read, write: if true;
    }
    match /payments/{paymentId} {
      allow read, write: if true;
    }
  }
}
